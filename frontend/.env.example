NEXT_PUBLIC_SANITY_PROJECT_ID="" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_STUDIO_URL="" #Optional, defaults to http://localhost:3333
SANITY_API_READ_TOKEN="" # Required - The read token for your Sanity project

# Resend - quotation form emails (server-only)
RESEND_API_KEY="" # Required - API key from https://resend.com/api-keys
QUOTE_FROM_EMAIL="Complex <onboarding@resend.dev>" # Required - use onboarding@resend.dev until the domain is verified
QUOTE_TO_EMAIL="" # Required - inbox that receives the quotation leads
