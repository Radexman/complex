{
  "name": "frontend",
  "private": true,
  "scripts": {
    "prebuild": "sanity typegen generate",
    "build": "next build",
    "predev": "npm run sanity:typegen",
    "dev": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sanity:typegen": "cd ../studio && sanity schema extract --enforce-required-fields --path ../sanity.schema.json && cd ../frontend && sanity typegen generate",
    "start": "next start",
    "type-check": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.4.0",
    "@sanity/client": "^7.22.1",
    "@sanity/image-url": "^2.1.1",
    "@sanity/uuid": "^3.0.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.5.0",
    "date-fns": "^4.4.0",
    "gsap": "^3.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "next": "^16.2.7",
    "next-sanity": "^13.0.8",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "resend": "^6.17.2",
    "sanity": "^5.28.0",
    "sanity-image": "^1.1.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sanity/prettier-config": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
